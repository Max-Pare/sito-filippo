{
	email {$ACME_EMAIL}
}

(cloudflare_tls) {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1 1.0.0.1
	}
}

filipporadiceosteopata.com, www.filipporadiceosteopata.com {
	import cloudflare_tls

	@www host www.filipporadiceosteopata.com
	redir @www https://filipporadiceosteopata.com{uri} 308

	encode zstd gzip

	header {
		-Server
	}

	@static_assets path /assets/* /static/* /favicon.ico
	header @static_assets Cache-Control "public, max-age=31536000, immutable"

	reverse_proxy 127.0.0.1:8080 {
		health_uri /health
		health_interval 30s
		health_timeout 5s

		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}

staging.filipporadiceosteopata.com {
	import cloudflare_tls

	encode zstd gzip

	header {
		-Server
		X-Robots-Tag "noindex, nofollow"
	}

	reverse_proxy 127.0.0.1:8081 {
		health_uri /health
		health_interval 30s
		health_timeout 5s

		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		header_up X-Forwarded-Proto {scheme}
		header_up X-Forwarded-Host {host}
	}
}
